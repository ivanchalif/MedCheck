API_BACKEND_HOST="127.0.0.1"
API_BACKEND_PORT=3001
API_PAYLOAD_MAX_SIZE="7mb"

# Optional: set a password to protect the app when deployed publicly.
# When set, users must enter this password before the app will work.
# The password is checked server-side only — it is never sent to the browser.
# Leave unset (or remove) for local/trusted-network use.
# ACCESS_PASSWORD="choose-a-strong-password-here"

# --- AI Provider Configuration ---
# Set these three variables to point at any OpenAI-compatible AI provider.

# Google Gemini (get a free key at https://aistudio.google.com/apikey)
AI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai"
AI_API_KEY="your-gemini-api-key-here"
AI_MODEL="gemini-2.0-flash"

# OpenAI
# AI_BASE_URL="https://api.openai.com/v1"
# AI_API_KEY="sk-..."
# AI_MODEL="gpt-4o"

# Ollama (local — run: ollama pull llama3)
# AI_BASE_URL="http://localhost:11434/v1"
# AI_API_KEY="ollama"
# AI_MODEL="llama3"

# LM Studio (local — enable the server inside LM Studio, then pick a loaded model)
# AI_BASE_URL="http://localhost:1234/v1"
# AI_API_KEY="lm-studio"
# AI_MODEL="your-loaded-model-name"

# Groq (hosted, very fast inference — https://console.groq.com)
# AI_BASE_URL="https://api.groq.com/openai/v1"
# AI_API_KEY="gsk_..."
# AI_MODEL="llama-3.3-70b-versatile"

# Together AI (hosted open-source models — https://api.together.ai)
# AI_BASE_URL="https://api.together.xyz/v1"
# AI_API_KEY="your-together-key"
# AI_MODEL="meta-llama/Llama-3-70b-chat-hf"
