# Copy this file to .env and fill in your values before deploying to cPanel.
# cPanel can also set these via Setup Node.js App > Environment Variables.

# ── AI Provider (required) ──────────────────────────────────────────────────
# Gemini example:
AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
AI_API_KEY=AIza...
AI_MODEL=gemini-2.0-flash

# OpenAI example:
# AI_BASE_URL=https://api.openai.com/v1
# AI_API_KEY=sk-...
# AI_MODEL=gpt-4o

# OpenRouter example (200+ models, has free tier):
# AI_BASE_URL=https://openrouter.ai/api/v1
# AI_API_KEY=sk-or-...
# AI_MODEL=google/gemini-2.0-flash-exp:free

# Groq example (fast inference, free tier):
# AI_BASE_URL=https://api.groq.com/openai/v1
# AI_API_KEY=gsk_...
# AI_MODEL=llama-3.3-70b-versatile

# ── Optional ─────────────────────────────────────────────────────────────────
# Password-protect the app (leave blank for open access):
# ACCESS_PASSWORD=your-secret-password

# PORT is assigned automatically by cPanel — do not set it here.
# NODE_ENV is set to production automatically by cPanel.
